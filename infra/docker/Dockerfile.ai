# Build context = repo root: `docker build -f infra/docker/Dockerfile.ai .`
FROM python:3.10-slim AS base
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/
ENV UV_COMPILE_BYTECODE=1 UV_LINK_MODE=copy
WORKDIR /app/apps/ai

# Install deps first (cached) from the lockfile, then the app source.
COPY apps/ai/pyproject.toml apps/ai/uv.lock ./
RUN uv sync --frozen --no-dev --no-install-project
COPY apps/ai/ ./
RUN uv sync --frozen --no-dev

ENV PATH="/app/apps/ai/.venv/bin:$PATH"
EXPOSE 8787
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8787"]
