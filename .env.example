# ─────────────────────────────────────────────────────────────────────────────
# VAYU AI — environment template. Copy to .env and fill in. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# --- Data tier (shared by both planes) ---
# Matches infra/docker/docker-compose.yml defaults for local dev.
DATABASE_URL=postgresql://vayu:vayu@localhost:5432/vayu
REDIS_URL=redis://localhost:6379/0

# --- Product plane: Next.js + Better Auth ---
BETTER_AUTH_SECRET=replace-with-32+char-random-string
BETTER_AUTH_URL=http://localhost:3000
# URL the BFF uses to reach the intelligence plane (server-to-server only):
AI_SERVICE_URL=http://localhost:8787
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional OAuth — leave blank to disable that provider:
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Intelligence plane: FastAPI ---
# JWKS endpoint the AI plane fetches to verify Better Auth JWTs.
# Better Auth serves it under its base path (/api/auth). Both planes share the
# issuer/audience below so the AI plane can validate `iss`/`aud`.
AUTH_JWKS_URL=http://localhost:3000/api/auth/jwks
AUTH_JWT_ISSUER=vayu
AUTH_JWT_AUDIENCE=vayu-ai

# --- Model providers (intelligence plane only) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Defaults; overridable per request:
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
DEFAULT_CHAT_MODEL=claude-sonnet-4-6

# --- Object storage (S3-compatible) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=vayu
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Observability ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=vayu

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info
