# ─────────────────────────────────────────────────────────────────────────────
# VAYU AI — environment template. Copy to .env and fill in. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# --- Data tier (shared by both planes) ---
# Matches infra/docker/docker-compose.yml defaults for local dev.
DATABASE_URL=postgresql://vayu:vayu@localhost:5432/vayu
REDIS_URL=redis://localhost:6379/0

# --- Product plane: Next.js + Better Auth ---
BETTER_AUTH_SECRET=replace-with-32+char-random-string
BETTER_AUTH_URL=http://localhost:3000
# URL the BFF uses to reach the intelligence plane (server-to-server only):
AI_SERVICE_URL=http://localhost:8787
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional OAuth — leave blank to disable that provider:
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Intelligence plane: FastAPI ---
# JWKS endpoint the AI plane fetches to verify Better Auth JWTs.
# Better Auth serves it under its base path (/api/auth). Both planes share the
# issuer/audience below so the AI plane can validate `iss`/`aud`.
AUTH_JWKS_URL=http://localhost:3000/api/auth/jwks
AUTH_JWT_ISSUER=vayu
AUTH_JWT_AUDIENCE=vayu-ai

# --- Model providers (intelligence plane only) ---
# Chat: any configured provider works; failover walks them in order.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
# Preferred chat provider: anthropic | openai | gemini | groq | openrouter
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_CHAT_MODEL=claude-opus-4-8
# Per-provider default models (used when a request doesn't pin one):
OPENAI_CHAT_MODEL=gpt-4o-mini
GEMINI_CHAT_MODEL=gemini-2.0-flash
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
OPENROUTER_CHAT_MODEL=anthropic/claude-3.5-sonnet
# Embeddings: openai | voyage  (dims differ → re-index when switching)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# --- RAG retrieval + vector store ---
RAG_HYBRID=true                 # vector + keyword fusion + MMR rerank
RAG_MAX_CONTEXT_CHARS=6000
# Vector store: pgvector (default, in-DB) | qdrant | chroma | pinecone
VECTOR_STORE=pgvector
VECTOR_COLLECTION=vayu_embeddings
QDRANT_URL=
QDRANT_API_KEY=
CHROMA_URL=
PINECONE_API_KEY=
PINECONE_INDEX_HOST=

# --- Security ---
RATE_LIMIT_PER_MIN=120

# --- Object storage (S3-compatible) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=vayu
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Observability ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=vayu

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info
