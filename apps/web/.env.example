# Next.js reads env from apps/web/.env.local. Copy from here (and the monorepo
# root .env.example for shared values).
DATABASE_URL=postgresql://vayu:vayu@localhost:5432/vayu
BETTER_AUTH_SECRET=replace-with-32+char-random-string
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
AI_SERVICE_URL=http://localhost:8787

# Must match the intelligence plane's verification settings:
AUTH_JWT_ISSUER=vayu
AUTH_JWT_AUDIENCE=vayu-ai

# Optional OAuth — leave blank to disable that provider:
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
